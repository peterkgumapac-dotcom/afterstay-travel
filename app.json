{
  "expo": {
    "name": "AfterStay Travel",
    "slug": "afterstay-travel",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon/afterstay-icon.png",
    "scheme": "afterstay",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afterstay.travel",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AfterStay needs access to your photo library to add trip moments.",
        "NSCameraUsageDescription": "AfterStay needs camera access to capture trip moments."
      },
      "icon": {
        "light": "./assets/icon/afterstay-icon.png",
        "dark": "./assets/icon/afterstay-icon-dark.png",
        "tinted": "./assets/icon/afterstay-icon-mono-black.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/afterstay-adaptive-foreground.png",
        "backgroundImage": "./assets/icon/afterstay-adaptive-background.png",
        "monochromeImage": "./assets/icon/afterstay-monochrome.png"
      },
      "package": "com.afterstay.travel",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "./plugins/withPackagingFix"
    ],
    "updates": {
      "url": "https://u.expo.dev/a804380e-5c0d-425e-ac2b-7c07b8b81fd4",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a804380e-5c0d-425e-ac2b-7c07b8b81fd4"
      }
    },
    "owner": "afterstay"
  }
}
